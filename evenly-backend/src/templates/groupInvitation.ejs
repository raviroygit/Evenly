<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>You're invited to join <%= groupName %> on <%= appName %></title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" valign="top" style="padding:0;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; border-collapse:separate;">
          <!-- Header -->
          <tr>
            <td bgcolor="#6366f1" align="center" style="background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 50%,#a855f7 100%); padding:32px 40px; border-top-left-radius:16px; border-top-right-radius:16px;">
              <p style="font-size:28px; font-weight:800; color:#ffffff; margin:0; letter-spacing:-0.5px;"><%= appName %></p>
              <p style="font-size:12px; color:#ffffff; opacity:0.85; margin-top:4px; letter-spacing:1.5px; text-transform:uppercase;"><%= subtitle %></p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td bgcolor="#000000" style="background-color:#000000; padding:40px;">
              <h1 style="font-size:22px; font-weight:700; color:#f3f4f6; margin:0 0 20px 0;">
                <% if (isExistingUser) { %>
                  <%= (msg && msg.inviteHeadingExisting) ? msg.inviteHeadingExisting : "You've been invited to a group!" %>
                <% } else { %>
                  <%= (msg && msg.inviteHeadingNew) ? msg.inviteHeadingNew : "Welcome to " + appName + "!" %>
                <% } %>
              </h1>

              <!-- Group info card -->
              <table role="presentation" width="100%" bgcolor="#1a1a24" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a24; border:1px solid #4f46e5; border-radius:10px; margin:0 0 24px 0;">
                <tr>
                  <td align="center" style="padding:18px 20px; text-align:center;">
                    <p style="margin:0 0 6px 0; font-size:18px; font-weight:700; color:#f3f4f6;"><%= groupName %></p>
                    <p style="margin:0; color:#a5b4fc; font-size:13px;"><%= (msg && msg.invitedByLabel) ? msg.invitedByLabel : 'Invited by' %> <strong style="color:#c7d2fe;"><%= inviterName %></strong></p>
                  </td>
                </tr>
              </table>

              <% if (isExistingUser) { %>
                <p style="font-size:15px; color:#9ca3af; line-height:1.7; margin:0 0 24px 0;">
                  <% if (msg && msg.bodyExisting) { %><%= msg.bodyExisting %><% } else { %><strong style="color:#f3f4f6;"><%= inviterName %></strong> has invited you to join the group "<strong style="color:#f3f4f6;"><%= groupName %></strong>" on <%= appName %>. Click the button below to accept the invitation and start sharing expenses with your group.<% } %>
                </p>
              <% } else { %>
                <p style="font-size:15px; color:#9ca3af; line-height:1.7; margin:0 0 24px 0;">
                  <% if (msg && msg.bodyNew) { %><%= msg.bodyNew %><% } else { %><strong style="color:#f3f4f6;"><%= inviterName %></strong> has invited you to join the group "<strong style="color:#f3f4f6;"><%= groupName %></strong>" on <%= appName %>. <%= appName %> makes it easy to split expenses, track who owes what, and settle up with friends, family, or colleagues.<% } %>
                </p>

                <h2 style="font-size:16px; font-weight:700; color:#f3f4f6; margin:0 0 14px 0;"><%= (msg && msg.whatYouCanDo) ? msg.whatYouCanDo : "What you can do with " + appName + ":" %></h2>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px 0;">
                  <tr><td style="padding:8px 0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tr>
                        <td valign="top" style="padding-right:14px; width:30px; font-size:18px;">💰</td>
                        <td style="color:#9ca3af; font-size:14px; line-height:1.6;"><%= (msg && msg.feature1) ? msg.feature1 : "Split bills and expenses easily" %></td>
                      </tr>
                    </table>
                  </td></tr>
                  <tr><td style="padding:8px 0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tr>
                        <td valign="top" style="padding-right:14px; width:30px; font-size:18px;">📊</td>
                        <td style="color:#9ca3af; font-size:14px; line-height:1.6;"><%= (msg && msg.feature2) ? msg.feature2 : "Track who owes what in real-time" %></td>
                      </tr>
                    </table>
                  </td></tr>
                  <tr><td style="padding:8px 0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tr>
                        <td valign="top" style="padding-right:14px; width:30px; font-size:18px;">🤝</td>
                        <td style="color:#9ca3af; font-size:14px; line-height:1.6;"><%= (msg && msg.feature3) ? msg.feature3 : "Settle up with group members" %></td>
                      </tr>
                    </table>
                  </td></tr>
                  <tr><td style="padding:8px 0;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tr>
                        <td valign="top" style="padding-right:14px; width:30px; font-size:18px;">📱</td>
                        <td style="color:#9ca3af; font-size:14px; line-height:1.6;"><%= (msg && msg.feature4) ? msg.feature4 : "Access from any device" %></td>
                      </tr>
                    </table>
                  </td></tr>
                </table>
              <% } %>

              <!-- CTA -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding:8px 0 16px 0;">
                    <a href="<%= invitationLink %>" style="display:inline-block; padding:16px 40px; background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 100%); color:#ffffff !important; text-decoration:none; border-radius:10px; font-weight:700; font-size:16px; letter-spacing:0.3px;">
                      <% if (isExistingUser) { %>
                        <%= (msg && msg.acceptInvitation) ? msg.acceptInvitation : "Accept Invitation" %>
                      <% } else { %>
                        <%= (msg && msg.openInBrowser) ? msg.openInBrowser : "Open in Browser" %>
                      <% } %>
                    </a>
                  </td>
                </tr>
              </table>

              <% if (!isExistingUser) { %>
                <!-- Download box (card) -->
                <table role="presentation" width="100%" bgcolor="#1a1a24" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a24; border:1px solid #4f46e5; border-radius:10px; margin:16px 0 0 0;">
                  <tr>
                    <td align="center" style="padding:20px; text-align:center;">
                      <p style="margin:0 0 8px 0; font-size:15px; font-weight:700; color:#f3f4f6;">📱 <%= (msg && msg.downloadBoxTitle) ? msg.downloadBoxTitle : "Download the " + appName + " App" %></p>
                      <p style="margin:0 0 16px 0; color:#a5b4fc; font-size:13px; line-height:1.6;">
                        <%= (msg && msg.downloadBoxText) ? msg.downloadBoxText : "For the best experience, download our mobile app and accept the invitation there!" %>
                      </p>
                      <a href="<%= appDownloadLink %>" style="display:inline-block; padding:14px 32px; background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 100%); color:#ffffff !important; text-decoration:none; border-radius:10px; font-weight:700; font-size:15px;">
                        📲 <%= (msg && msg.getTheApp) ? msg.getTheApp : "Get the App" %>
                      </a>
                      <p style="margin:14px 0 0 0; color:#9ca3af; font-size:12px;">
                        <%= (msg && msg.worksOnDevices) ? msg.worksOnDevices : "Works on both Android and iOS" %>
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Note (card) -->
                <table role="presentation" width="100%" bgcolor="#1a1a24" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a24; border:1px solid #5a4520; border-radius:10px; margin-top:16px;">
                  <tr>
                    <td align="center" style="padding:14px 18px; font-size:13px; color:#fbbf24; line-height:1.6; text-align:center;">
                      <strong style="color:#fcd34d;">Note:</strong> <%= (msg && msg.downloadNote) ? msg.downloadNote : "The \"Get the App\" button will automatically detect your device and take you to the Play Store (Android) or App Store (iOS). Once installed, open the app and accept your invitation!" %>
                    </td>
                  </tr>
                </table>
              <% } %>

              <!-- Expiry (card) -->
              <table role="presentation" width="100%" bgcolor="#1a1a24" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a24; border:1px solid #5a4520; border-radius:10px; margin-top:20px;">
                <tr>
                  <td align="center" style="padding:14px 18px; font-size:13px; color:#fbbf24; line-height:1.6; text-align:center;">
                    <%= (msg && msg.expireNote) ? msg.expireNote : "This invitation will expire in 7 days. If you don't want to join this group, you can simply ignore this email." %>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:32px 0 0 0;">
                <tr><td bgcolor="#2d2d3d" height="1" style="background-color:#2d2d3d; height:1px; line-height:1px; font-size:0;">&nbsp;</td></tr>
              </table>

              <p style="font-size:13px; color:#9ca3af; line-height:1.7; margin:20px 0 0 0;">
                <%= (msg && msg.footerSent) ? msg.footerSent : "This email was sent by " + appName + ". If you have any questions, please contact us." %>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td bgcolor="#6366f1" align="center" style="background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 50%,#a855f7 100%); padding:24px 40px 32px; border-bottom-left-radius:16px; border-bottom-right-radius:16px;">
              <p style="font-size:13px; font-weight:600; color:#ffffff; margin:0 0 4px 0;"><a href="<%= orgUrl %>" target="_blank" style="color:#ffffff; text-decoration:none;"><%= appName %></a> &middot; <%= orgSlug %></p>
              <p style="font-size:11px; color:#ffffff; opacity:0.75; margin:0;">Powered By <a href="https://nxtgenaidev.com/" target="_blank" style="color:#ffffff; text-decoration:underline;">NextGen AI Dev Private Limited</a>. &copy; <%= year %> All rights reserved.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
