<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>Khata Account Closed - <%= appName %></title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" valign="top" style="padding:0;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; border-collapse:separate;">
          <!-- Header -->
          <tr>
            <td bgcolor="#6366f1" align="center" style="background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 50%,#a855f7 100%); padding:32px 40px; border-top-left-radius:16px; border-top-right-radius:16px;">
              <p style="font-size:28px; font-weight:800; color:#ffffff; margin:0; letter-spacing:-0.5px;"><%= appName %></p>
              <p style="font-size:12px; color:#ffffff; opacity:0.85; margin-top:4px; letter-spacing:1.5px; text-transform:uppercase;"><%= subtitle %></p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td bgcolor="#000000" style="background-color:#000000; padding:40px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px 0;">
                <tr>
                  <td style="padding:6px 14px; background-color:#1a1a24; border:1px solid #5a2020; border-radius:999px; font-size:12px; font-weight:700; color:#fca5a5; letter-spacing:0.5px;">🔴 Account Closed</td>
                </tr>
              </table>

              <h1 style="font-size:22px; font-weight:700; color:#f3f4f6; margin:0 0 12px 0;">Hello <%= customerName %>,</h1>
              <p style="font-size:15px; color:#9ca3af; line-height:1.7; margin:0 0 24px 0;">
                <strong style="color:#f3f4f6;"><%= userName %></strong> has removed you from their Khata (ledger book) on <%= appName %>.
              </p>

              <!-- Closure card (content centered) -->
              <table role="presentation" width="100%" bgcolor="#1a1a24" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a24; border:1px solid #5a2020; border-radius:10px; margin:0 0 16px 0;">
                <tr>
                  <td align="center" style="padding:18px 20px; text-align:center;">
                    <p style="margin:0 0 8px 0; font-size:15px; font-weight:700; color:#fecaca;">Account Closure</p>
                    <p style="margin:0 0 12px 0; color:#fca5a5; font-size:13px; line-height:1.6;">
                      Your Khata account with <%= userName %> has been closed and all transaction history has been archived.
                    </p>
                    <% if (finalBalance && parseFloat(finalBalance) !== 0) { %>
                    <p style="margin:0 0 6px 0; color:#fecaca; font-size:14px;">
                      <strong style="color:#fee2e2;">Final Balance:</strong> ₹<%= Math.abs(parseFloat(finalBalance)).toFixed(2) %>
                      (<%= parseFloat(finalBalance) > 0 ? 'You will give' : 'You will get' %>)
                    </p>
                    <p style="margin:0; color:#fca5a5; font-size:13px; line-height:1.6;">
                      ⚠️ Please settle this balance with <%= userName %> if not already done.
                    </p>
                    <% } else { %>
                    <p style="margin:0; color:#86efac; font-size:14px;">
                      ✅ Your balance was settled when the account was closed.
                    </p>
                    <% } %>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 24px 0; color:#9ca3af; font-size:13px; line-height:1.7;">
                You will no longer receive transaction notifications from this Khata.
              </p>

              <!-- CTA -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding:8px 0;">
                    <a href="<%= appOpenLink %>" style="display:inline-block; padding:16px 40px; background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 100%); color:#ffffff !important; text-decoration:none; border-radius:10px; font-weight:700; font-size:16px; letter-spacing:0.3px;">📱 Open in App</a>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:32px 0 0 0;">
                <tr><td bgcolor="#2d2d3d" height="1" style="background-color:#2d2d3d; height:1px; line-height:1px; font-size:0;">&nbsp;</td></tr>
              </table>

              <p style="font-size:13px; color:#9ca3af; line-height:1.7; margin:20px 0 0 0;">This is an automated notification from <%= appName %> Khata.</p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td bgcolor="#6366f1" align="center" style="background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 50%,#a855f7 100%); padding:24px 40px 32px; border-bottom-left-radius:16px; border-bottom-right-radius:16px;">
              <p style="font-size:13px; font-weight:600; color:#ffffff; margin:0 0 4px 0;"><a href="<%= orgUrl %>" target="_blank" style="color:#ffffff; text-decoration:none;"><%= appName %></a> &middot; <%= orgSlug %></p>
              <p style="font-size:11px; color:#ffffff; opacity:0.75; margin:0;">Powered By <a href="https://nxtgenaidev.com/" target="_blank" style="color:#ffffff; text-decoration:underline;">NextGen AI Dev Private Limited</a>. &copy; <%= year %> All rights reserved.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
