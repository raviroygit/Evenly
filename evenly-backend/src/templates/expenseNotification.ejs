<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>New Expense Added - <%= appName %></title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" valign="top" style="padding:0;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; border-collapse:separate;">
          <!-- Header -->
          <tr>
            <td bgcolor="#6366f1" align="center" style="background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 50%,#a855f7 100%); padding:32px 40px; border-top-left-radius:16px; border-top-right-radius:16px;">
              <p style="font-size:28px; font-weight:800; color:#ffffff; margin:0; letter-spacing:-0.5px;"><%= appName %></p>
              <p style="font-size:12px; color:#ffffff; opacity:0.85; margin-top:4px; letter-spacing:1.5px; text-transform:uppercase;"><%= subtitle %></p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td bgcolor="#000000" style="background-color:#000000; padding:40px;">
              <h1 style="font-size:22px; font-weight:700; color:#f3f4f6; margin:0 0 8px 0;"><%= (msg && msg.heading) ? msg.heading : "New Expense Added" %></h1>
              <p style="font-size:14px; color:#9ca3af; line-height:1.7; margin:0 0 24px 0;"><%= (msg && msg.subtitle) ? msg.subtitle : "Someone in your group has added a new expense" %></p>

              <!-- Expense card (content centered) -->
              <table role="presentation" width="100%" bgcolor="#1a1a24" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a24; border:1px solid #4f46e5; border-radius:10px;">
                <tr>
                  <td align="center" style="padding:22px; text-align:center;">
                    <p style="margin:0 0 18px 0; font-size:18px; font-weight:700; color:#f3f4f6;"><%= expense.title %></p>

                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr><td align="center" style="padding:6px 0; text-align:center;">
                        <p style="margin:0 0 2px 0; color:#6b7280; font-size:11px; text-transform:uppercase; letter-spacing:0.6px;"><%= (msg && msg.addedByLabel) ? msg.addedByLabel : "Added by:" %></p>
                        <p style="margin:0; color:#f3f4f6; font-size:14px; font-weight:600;"><%= addedBy.name %></p>
                      </td></tr>
                      <tr><td align="center" style="padding:6px 0; text-align:center;">
                        <p style="margin:0 0 2px 0; color:#6b7280; font-size:11px; text-transform:uppercase; letter-spacing:0.6px;"><%= (msg && msg.groupLabel) ? msg.groupLabel : "Group:" %></p>
                        <p style="margin:0; color:#f3f4f6; font-size:14px; font-weight:600;"><%= group.name %></p>
                      </td></tr>
                      <tr><td align="center" style="padding:6px 0; text-align:center;">
                        <p style="margin:0 0 2px 0; color:#6b7280; font-size:11px; text-transform:uppercase; letter-spacing:0.6px;"><%= (msg && msg.dateLabel) ? msg.dateLabel : "Date:" %></p>
                        <p style="margin:0; color:#f3f4f6; font-size:14px; font-weight:600;"><%= new Date(expense.date).toLocaleDateString() %></p>
                      </td></tr>
                      <% if (expense.description) { %>
                      <tr><td align="center" style="padding:6px 0; text-align:center;">
                        <p style="margin:0 0 2px 0; color:#6b7280; font-size:11px; text-transform:uppercase; letter-spacing:0.6px;"><%= (msg && msg.descriptionLabel) ? msg.descriptionLabel : "Description:" %></p>
                        <p style="margin:0; color:#f3f4f6; font-size:14px; font-weight:600;"><%= expense.description %></p>
                      </td></tr>
                      <% } %>
                      <tr><td align="center" style="padding:6px 0; text-align:center;">
                        <p style="margin:0 0 2px 0; color:#6b7280; font-size:11px; text-transform:uppercase; letter-spacing:0.6px;"><%= (msg && msg.categoryLabel) ? msg.categoryLabel : "Category:" %></p>
                        <p style="margin:0; color:#f3f4f6; font-size:14px; font-weight:600;"><%= expense.category %></p>
                      </td></tr>
                    </table>

                    <p style="margin:18px 0 0 0; font-size:30px; font-weight:800; color:#a5b4fc; letter-spacing:-0.5px;">
                      <%= (typeof currencySymbol !== 'undefined' && currencySymbol) ? currencySymbol : '₹' %><%= parseFloat(expense.totalAmount).toFixed(2) %>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Your share card -->
              <table role="presentation" width="100%" bgcolor="#1a1a24" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a24; border:1px solid #4f46e5; border-radius:10px; margin-top:16px;">
                <tr>
                  <td align="center" style="padding:18px 20px; text-align:center;">
                    <p style="margin:0 0 6px 0; font-size:11px; text-transform:uppercase; letter-spacing:1px; color:#a5b4fc; font-weight:700;"><%= (msg && msg.yourShareLabel) ? msg.yourShareLabel : "Your share:" %></p>
                    <p style="margin:0 0 8px 0; font-size:24px; font-weight:800; color:#f3f4f6;">
                      <%= (typeof currencySymbol !== 'undefined' && currencySymbol) ? currencySymbol : '₹' %><%= parseFloat(userSplit.amount).toFixed(2) %>
                    </p>
                    <p style="margin:0; color:#a5b4fc; font-size:13px; line-height:1.6;">
                      <%= (msg && msg.payToMessage) ? msg.payToMessage : "You need to pay this amount to " + addedBy.name %>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- CTA -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding:28px 0 8px 0;">
                    <a href="<%= appOpenLink %>" style="display:inline-block; padding:16px 40px; background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 100%); color:#ffffff !important; text-decoration:none; border-radius:10px; font-weight:700; font-size:16px; letter-spacing:0.3px;">📱 <%= (msg && msg.viewInApp) ? msg.viewInApp : "Open in App" %></a>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:32px 0 0 0;">
                <tr><td bgcolor="#2d2d3d" height="1" style="background-color:#2d2d3d; height:1px; line-height:1px; font-size:0;">&nbsp;</td></tr>
              </table>

              <p style="font-size:13px; color:#9ca3af; line-height:1.7; margin:20px 0 0 0;">
                <%= (msg && msg.footer) ? msg.footer : "This is an automated notification from " + appName + "." %>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td bgcolor="#6366f1" align="center" style="background-color:#6366f1; background-image:linear-gradient(135deg,#6366f1 0%,#8b5cf6 50%,#a855f7 100%); padding:24px 40px 32px; border-bottom-left-radius:16px; border-bottom-right-radius:16px;">
              <p style="font-size:13px; font-weight:600; color:#ffffff; margin:0 0 4px 0;"><a href="<%= orgUrl %>" target="_blank" style="color:#ffffff; text-decoration:none;"><%= appName %></a> &middot; <%= orgSlug %></p>
              <p style="font-size:11px; color:#ffffff; opacity:0.75; margin:0;">Powered By <a href="https://nxtgenaidev.com/" target="_blank" style="color:#ffffff; text-decoration:underline;">NextGen AI Dev Private Limited</a>. &copy; <%= year %> All rights reserved.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
