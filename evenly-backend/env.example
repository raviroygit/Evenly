# Evenly Backend Environment Variables
# Copy this file to .env and update the values

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
EVENLY_DATABASE_URL=your_neon_database_url_here

# Auth Service
AUTH_SERVICE_URL=https://auth-api.nxtgenaidev.com/api/v1/auth
AUTH_SERVICE_API_KEY=your_auth_service_api_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
# Evenly app org (fixed for EvenlySplit; optional – app has default)
EVENLY_ORGANIZATION_ID=696fc87397e67400b0335682

# CORS
CORS_ORIGIN=http://localhost:8081

# Rate Limiting (increased for development)
RATE_LIMIT_MAX=10000
RATE_LIMIT_TIME_WINDOW=60000

# Swagger
SWAGGER_HOST=localhost:3001
SWAGGER_SCHEMES=http,https

# Email Configuration
EMAIL_HOST=smtp.zoho.in
EMAIL_PORT=465
EMAIL_USER=no-reply@nxtgenaidev.com
EMAIL_PASS=your_email_password_here
SUPPORT_EMAIL=support@evenly.com

# App Configuration
APP_BASE_URL=https://7e4c19dda31c.ngrok-free.app

# Cloudinary Configuration
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
# Cloud name: codelength
CLOUDINARY_CLOUD_NAME=codelength
CLOUDINARY_API_KEY=983787797957675
CLOUDINARY_API_SECRET=BAh8q7a6EfVuEEeuMVQmShnJQvI

# Push Notifications — iOS (APNs): inline PEM (APNS_KEY) or file path (APNS_KEY_PATH)
APNS_KEY_PATH=./certs/apns-key.p8
APNS_KEY_ID=9TB3SV933G
APNS_TEAM_ID=3ZGW2224V2
APNS_BUNDLE_ID=com.nxtgenaidev.evenly
# APNS_PRODUCTION=false   # override; defaults to NODE_ENV === 'production'

# Push Notifications — Android (FCM)
FCM_PROJECT_ID=nextgenai-f6743
# Service account for sending off-GCP (Firebase Console -> Service accounts -> Generate key).
# Inline JSON or a mounted path; falls back to applicationDefault() / GOOGLE_APPLICATION_CREDENTIALS.
# FCM_SERVICE_ACCOUNT_JSON=
# FCM_SERVICE_ACCOUNT_PATH=/secrets/firebase-service-account.json

# Test Configuration (for API testing scripts)
API_BASE_URL=http://localhost:3001
TEST_AUTH_TOKEN=your_test_auth_token_here
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword