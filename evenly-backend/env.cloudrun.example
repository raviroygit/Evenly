# Evenly Backend Cloud Run Environment Variables
NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=nextgen-ai-dev
REGION=us-central1
SERVICE_NAME=evenly-backend

# Application URLs
BASE_URL=https://evenly-api.nxtgenaidev.com
DOMAIN=evenly-api.nxtgenaidev.com

# CORS Origins
ORIGIN1=https://evenly.app
ORIGIN2=https://www.evenly.app

# Database (use Google Cloud Secret Manager)
EVENLY_DATABASE_URL=your_neon_database_url_here

# Auth Service
AUTH_SERVICE_URL=https://auth-api.nxtgenaidev.com/api/v1/auth
AUTH_SERVICE_API_KEY=your_auth_service_api_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
# Evenly app org (fixed for EvenlySplit; optional – app has default)
EVENLY_ORGANIZATION_ID=696fc87397e67400b0335682

# Google OAuth — required for social login to work on deployed service
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# CORS
CORS_ORIGIN=https://evenly.app

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_TIME_WINDOW=60000

# Swagger
SWAGGER_HOST=evenly-api.nxtgenaidev.com
SWAGGER_SCHEMES=https

# Email Configuration
EMAIL_HOST=smtp.zoho.in
EMAIL_PORT=465
EMAIL_USER=no-reply@nxtgenaidev.com
EMAIL_PASS=your_email_password_here
SUPPORT_EMAIL=support@evenly.com

# App Configuration
APP_BASE_URL=https://evenly-api.nxtgenaidev.com

# Push Notifications — iOS (APNs)
# Provide the .p8 key either as an inline PEM (APNS_KEY) or a file path
# (APNS_KEY_PATH). On Coolify/containers, inline is easiest. Keep real values
# in a secret, not in git.
APNS_KEY=
# APNS_KEY_PATH=./certs/apns-key.p8
APNS_KEY_ID=9TB3SV933G
APNS_TEAM_ID=3ZGW2224V2
APNS_BUNDLE_ID=com.nxtgenaidev.evenly
# true on production hosts so APNs uses the production gateway
APNS_PRODUCTION=true

# Push Notifications — Android (FCM)
FCM_PROJECT_ID=nextgen-ai-dev
# REQUIRED off-GCP (no metadata server on Coolify/Hetzner): provide the Firebase
# service-account JSON inline (FCM_SERVICE_ACCOUNT_JSON) or as a mounted file
# path (FCM_SERVICE_ACCOUNT_PATH). Generate it in Firebase Console -> Project
# Settings -> Service accounts -> Generate new private key. Without one of these,
# FCM sends fail with "Could not load the default credentials".
FCM_SERVICE_ACCOUNT_JSON=
# FCM_SERVICE_ACCOUNT_PATH=/secrets/firebase-service-account.json
